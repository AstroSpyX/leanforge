# Copy this file to .env and fill in your real key:
#   cp .env.example .env
#   # then edit .env
#
# .env is gitignored — never commits.
# .env.example IS committed — keep it free of real secrets.

ANTHROPIC_API_KEY=sk-ant-api03-PUT-YOUR-KEY-HERE

# Required only when using Gemini models (gemini-flash-lite,
# gemini-flash, gemini-pro). Anthropic-only setups can leave it unset.
GOOGLE_API_KEY=PUT-YOUR-GOOGLE-AI-STUDIO-KEY-HERE

# Optional: override the default model used by llm.ask.
# Not currently read by the code, but documented here for future use.
# LEANFORGE_DEFAULT_MODEL=sonnet
